{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Lane",
  "description": "Agent-native payments: draft a purchase, approve it, and let Lane complete the merchant checkout — in Claude Code or over a headless API.",
  "colors": {
    "primary": "#1201FF",
    "light": "#4D3DFF",
    "dark": "#1201FF"
  },
  "background": {
    "color": {
      "light": "#F6F6F6",
      "dark": "#000000"
    }
  },
  "fonts": {
    "heading": {
      "family": "At Aero",
      "weight": 700,
      "source": "/fonts/at-aero-bold.woff2",
      "format": "woff2"
    },
    "body": {
      "family": "At Aero",
      "weight": 400,
      "source": "/fonts/at-aero-regular.woff2",
      "format": "woff2"
    }
  },
  "logo": {
    "light": "https://assets.getonlane.com/brand/lane-lockup-white.svg",
    "dark": "https://assets.getonlane.com/brand/lane-lockup-black.svg",
    "href": "https://getonlane.com"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "index",
              "concepts/model"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "security/overview",
              "security/reporting"
            ]
          }
        ]
      },
      {
        "tab": "Lane Plugin",
        "groups": [
          {
            "group": "Plugin",
            "pages": [
              "plugin/installation",
              "plugin/setup",
              "plugin/quickstart",
              "plugin/purchase-flow",
              "plugin/architecture",
              "plugin/troubleshooting"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "plugin/reference/skills",
              "plugin/reference/cli",
              "plugin/reference/mcp-tools",
              "plugin/reference/configuration"
            ]
          }
        ]
      },
      {
        "tab": "Order API",
        "groups": [
          {
            "group": "Guides",
            "pages": [
              "api/overview",
              "api/setup",
              "api/authentication",
              "api/quickstart"
            ]
          },
          {
            "group": "Working with orders",
            "pages": [
              "api/create-order",
              "api/order-lifecycle",
              "api/webhooks",
              "api/polling",
              "api/needs-input"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api/idempotency",
              "api/errors",
              "api/limits-and-pilot"
            ]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/Lane-Technologies-Inc/lane-plugin"
      }
    ],
    "primary": {
      "type": "button",
      "label": "getonlane.com",
      "href": "https://getonlane.com"
    }
  },
  "footer": {
    "socials": {
      "website": "https://getonlane.com",
      "github": "https://github.com/Lane-Technologies-Inc"
    }
  },
  "contextual": {
    "options": [
      "download-spec",
      "chatgpt",
      "claude",
      "perplexity",
      "grok",
      "aistudio",
      "mcp",
      "add-mcp",
      "cursor",
      "copy",
      "view",
      "assistant"
    ],
    "display": "header"
  }
}
